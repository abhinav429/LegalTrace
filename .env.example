# App URL (optional locally; set in Vercel for correct Open Graph / canonical URLs)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Show Ingest / Sources / Search / Chat on production builds (e.g. Vercel). Omit or false = "Demo only" message on /workspace.
# NEXT_PUBLIC_WORKSPACE_IN_PRODUCTION=true

# OpenAI (via Vercel AI SDK)
OPENAI_API_KEY=

# Optional: OpenAI-compatible API base (proxies, Azure OpenAI, etc.)
# OPENAI_BASE_URL=

# Database — use the same connection string for both, or only POSTGRES_URL
POSTGRES_URL=
DATABASE_URL=

# node-pg pool (same database as above; required for vector queries)
PGUSER=
PGPASSWORD=
PGHOST=
PGPORT=
PGDATABASE=
